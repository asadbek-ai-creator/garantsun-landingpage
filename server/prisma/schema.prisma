generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id                String   @id @default(cuid())
  fullName          String
  phone             String
  address           String
  region            String
  calculatorResults Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
